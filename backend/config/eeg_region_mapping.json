  "seizure_type_default_regions": {
    "_disclaimer": "Fallback DEMO mapping only. Based on typical EEG onset patterns from ILAE literature. NOT clinical localization.",
    "_reference": "Fisher RS et al. (2017). Operational classification of seizure types by the ILAE. Epilepsia 58(4):522-530.",

    "Normal":         { "region": null,                "lobe": null,       "side": "none",    "confidence_label": "n/a",   "typical_channels": [] },
    "Absence":        { "region": "Frontal Midline",   "lobe": "frontal",  "side": "midline", "confidence_label": "demo",  "typical_channels": ["Fz","F3","F4"], "note": "3Hz spike-wave generalized; frontal max in typical absence" },
    "Focal Temporal": { "region": "Left Temporal",     "lobe": "temporal", "side": "left",    "confidence_label": "demo",  "typical_channels": ["T3","T7","F7"],  "note": "Mesial temporal lobe epilepsy (MTLE); may be R or L" },
    "Focal Frontal":  { "region": "Left Frontal",      "lobe": "frontal",  "side": "left",    "confidence_label": "demo",  "typical_channels": ["F3","F7","Fz"],  "note": "Supplementary motor area or prefrontal onset" },
    "Myoclonic":      { "region": "Vertex (Motor)",    "lobe": "central",  "side": "midline", "confidence_label": "demo",  "typical_channels": ["Cz","C3","C4"],  "note": "Generalized polyspike at vertex; corticospinal drive" },
    "Tonic":          { "region": "Left Motor Cortex", "lobe": "central",  "side": "left",    "confidence_label": "demo",  "typical_channels": ["C3","Cz","F3"],  "note": "Diffuse fast beta onset from motor cortex" },
    "Tonic-Clonic":   { "region": "Frontal Midline",   "lobe": "frontal",  "side": "midline", "confidence_label": "demo",  "typical_channels": ["Fz","Cz","Pz"],  "note": "Generalized bihemispheric; frontal max during tonic phase" }
  },

  "lobes": {
    "frontal":   { "color_normal": "#1e3a8a", "color_alert": "#ef4444", "label": "Frontal Lobe",    "function": "Motor control, planning, executive function, Broca's area" },
    "temporal":  { "color_normal": "#4c1d95", "color_alert": "#f97316", "label": "Temporal Lobe",   "function": "Auditory processing, declarative memory (hippocampus), language (Wernicke)" },
    "parietal":  { "color_normal": "#065f46", "color_alert": "#eab308", "label": "Parietal Lobe",   "function": "Sensory integration, spatial awareness, attention networks" },
    "occipital": { "color_normal": "#164e63", "color_alert": "#ec4899", "label": "Occipital Lobe",  "function": "Primary visual cortex (V1), visual pattern recognition" },
    "central":   { "color_normal": "#78350f", "color_alert": "#dc2626", "label": "Central (Motor)", "function": "Primary motor cortex (M1), somatosensory cortex (S1)" }
  },

  "thresholds": {
    "stable":    { "max_risk": 0.40, "alert_level": "info",   "color": "#22c55e", "action": "Continue monitoring" },
    "elevated":  { "min_risk": 0.40, "max_risk": 0.60, "alert_level": "yellow", "color": "#eab308", "action": "Increase observation frequency" },
    "preictal":  { "min_risk": 0.60, "max_risk": 0.80, "alert_level": "orange", "color": "#f97316", "action": "Notify caregiver, prepare for seizure" },
    "ictal":     { "min_risk": 0.80, "alert_level": "red",    "color": "#ef4444", "action": "EMERGENCY — contact caregiver and/or emergency services" }
  },

  "highlight_intensity": {
    "_description": "How to compute visual highlight intensity from seizure_risk",
    "formula": "intensity = max(0, (risk - threshold_min) / (1.0 - threshold_min))",
    "threshold_min": 0.40,
    "color_stable":   "#22c55e",
    "color_elevated": "#eab308",
    "color_preictal": "#f97316",
    "color_ictal":    "#ef4444"
  }
